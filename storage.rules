rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // User resumes: only the owning user, max 10 MB
    match /resumes/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid
                         && request.resource.size < 10 * 1024 * 1024;
    }

    // Adzuna snapshots: only Cloud Functions (admin SDK)
    match /adzuna-snapshots/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
